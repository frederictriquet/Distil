# Orchestrator working dir
.orchestrator/

# Node / SvelteKit
# No trailing slash: also ignore a `node_modules` *symlink* (a trailing-slash
# rule matches directories only, which once let an absolute-path symlink slip
# past this ignore and get committed).
node_modules
/build
/.svelte-kit
/package
.env
.env.*
!.env.example
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Données locales de l'app : base SQLite (ex. data/distil.db)
# et cache des dépôts KB clonés (ex. data/kb-cache/).
/data/
