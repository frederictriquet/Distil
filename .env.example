# Environment configuration template for Distil.
# Copy this file to `.env` and fill in the real values (`.env` is not
# versioned). Never commit real secrets.

# Application password (single-user authentication).
APP_PASSWORD=change-me

# Secret used to sign (HMAC) the session cookie.
# REQUIRED: must be at least 16 characters and must not be a known placeholder
# (values like this template's default are rejected). A too-short, absent, or
# placeholder secret disables sessions and blocks login — the server refuses to
# authenticate rather than signing with a forgeable key.
# Use a long random value, e.g. `openssl rand -hex 32`.
SESSION_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database file (created/opened by the application).
DATABASE_PATH=data/distil.db

# Public origin of the application, required by adapter-node in production
# when it runs behind a reverse proxy (otherwise POST requests are rejected).
# See https://svelte.dev/docs/kit/adapter-node#environment-variables-origin-protocolheader-hostheader-and-port-header
ORIGIN=http://localhost:3000

# Header adapter-node should read the real client IP from when running behind a
# reverse proxy (e.g. nginx/caddy). REQUIRED in that deployment: the login
# rate-limiter keys off the client address, so without this every request
# appears to come from the proxy's IP — a single shared key — and a few wrong
# passwords from anyone would lock the real user out. Set it to the header your
# proxy sets (commonly `x-forwarded-for`) and make sure the proxy overwrites,
# not appends, that header. Leave unset only for direct (non-proxied) exposure.
# See https://svelte.dev/docs/kit/adapter-node#environment-variables-address-header
ADDRESS_HEADER=
