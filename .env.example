# Modèle de configuration d'environnement pour Distil.
# Copier ce fichier en `.env` puis renseigner les vraies valeurs (le `.env`
# n'est pas versionné). Les variables seront réellement câblées à la tâche 1.5.

# Mot de passe de l'application (authentification mono-utilisateur).
APP_PASSWORD=change-me

# Secret utilisé pour signer le cookie de session.
# En production, utiliser une valeur longue et aléatoire (ex. `openssl rand -hex 32`).
SESSION_SECRET=change-me-to-a-long-random-string

# Chemin du fichier de base de données SQLite (créé/ouvert par l'application).
DATABASE_PATH=data/distil.db

# Origine publique de l'application, requise par adapter-node en production
# lorsqu'il tourne derrière un proxy inverse (sinon les requêtes POST sont rejetées).
# Voir https://svelte.dev/docs/kit/adapter-node#environment-variables-origin-protocolheader-hostheader-and-port-header
ORIGIN=http://localhost:3000
